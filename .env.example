# Configurações do Supabase (Públicas e Privadas)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Configurações do Stripe (Públicas e Privadas)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Preços do Stripe para os planos de assinatura
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PREMIUM=price_...

# Configuração da Runware API
RUNWARE_API_KEY=your-runware-api-key

# URL da Aplicação (usada em redirects do Stripe e callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000
